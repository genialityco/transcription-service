# Puerto en el que corre el servicio
PORT=5001

# Ruta al binario compilado de whisper.cpp
# Por defecto apunta a ./build/bin/whisper-cli (generado por setup.sh)
WHISPER_BIN=./build/bin/whisper-cli

# Ruta al modelo ggml
# Por defecto apunta a ./models/ggml-large-v3-q5_0.bin (descargado por setup.sh)
WHISPER_MODEL=./models/ggml-large-v3-q5_0.bin

# Idioma de transcripción (es, en, fr, pt, etc.)
WHISPER_LANG=es

# API key de Google Gemini para generación de embeddings
GEMINI_API_KEY=your_gemini_api_key_here
